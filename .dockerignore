# ─── .dockerignore ─────────────────────────────────────────────────
# Keep the Docker build context small and avoid invalidating the
# cargo layer cache on unrelated file changes.

# Build artifacts
target/
**/target/
dist/
**/dist/

# Frontend (not needed in the CLI-only image — built separately)
desktop/frontend/node_modules/
desktop/frontend/.vite/
desktop/frontend/dist/

# Desktop (Tauri — ships as native installer, not in this image)
desktop/target/

# Git
.git/
.gitignore

# Docs and metadata
docs/
*.md
!AGENTS.md
!VISION.md
LICENSE

# CI and editor config
.github/
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Data and config (runtime, not build-time)
data/
config/
*.db
*.sqlite
*.sqlite3
*.vault.json

# Environment
.env
.env.*
