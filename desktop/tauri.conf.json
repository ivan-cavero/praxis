{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "praxis",
  "identifier": "com.praxis.desktop",
  "version": "0.6.1",
  "build": {
    "frontendDist": "../dashboard/dist",
    "devUrl": "http://localhost:3000",
"beforeDevCommand": "cd dashboard && bun run dev",
"beforeBuildCommand": "cd dashboard && bun run build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/256x256.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "praxis",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ivan-cavero/praxis/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCNEY3QkNGMERDMEUyODgKUldTSTRzQU56M3RQNjR1OVJnZUxWczZyTXJHdlJEOUtyRFZvSkFtbVJzblluMERkdUdnbUR1d2YK",
      "dangerousInsecureTransportProtocol": false
    }
  }
}
